# Local runtime caches written by the interactive server (routes/dashboard-full.js).
# The CI refresh (scripts/refresh.js) does not produce these — they are local-only.
public/data/url_*_cache.json

# Local screenshot cache — hash-keyed (32 hex chars) files the interactive server
# writes on demand. Production serves screenshots from Netlify Blobs, and the UI's
# static fallback uses the subdomain-named files (e.g. abarth-core-desktop-…png),
# which stay tracked. These hash-named copies are local-only, so keep them on disk
# but out of git. The 32-char class matches ONLY hashes, never the hyphenated names.
public/screenshots/[0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f][0-9a-f].png
